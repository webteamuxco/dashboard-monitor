# --- Error monitoring driver ---
# Drives the server-side Factory (src/lib/errorMonitor/factory/ErrorMonitorFactory.ts).
# Supported values: glitchtip
NEXT_PUBLIC_ERROR_MONITOR_DRIVER=glitchtip

# --- Log monitoring driver ---
# Drives the server-side Factory (src/lib/logMonitor/factory/LogMonitorResolver.ts).
# Supported values: glitchtip
NEXT_PUBLIC_LOG_MONITOR_DRIVER=glitchtip

# --- Tracker monitoring driver ---
# Drives the server-side Factory (src/lib/trackerMonitor/GetTrackerMonitor.ts).
# Supported values: posthog
NEXT_PUBLIC_TRACKER_MONITOR_DRIVER=posthog

# --- GlitchTip ---
# Used by the Glitchtip adapters (errorMonitor and logMonitor).
GLITCHTIP_URL=https://app.glitchtip.com
GLITCHTIP_TOKEN=
GLITCHTIP_ORGANIZATION_SLUG=

# --- PostHog ---
# Only used when NEXT_PUBLIC_TRACKER_MONITOR_DRIVER=posthog.
POSTHOG_HOST=https://eu.posthog.com
POSTHOG_PROJECT_ID=
POSTHOG_PERSONAL_API_KEY=

# --- Dashboard ---
# Label displayed centered in the dashboard header.
NEXT_PUBLIC_PROJECT_TITLE=
# GlitchTip project displayed by default on the kiosk page.
DASHBOARD_DEFAULT_PROJECT_ID=
# Auto-refresh interval on the kiosk page (ms).
DASHBOARD_REFRESH_INTERVAL_MS=30000
# Enables interactive controls on the dashboard (true/false).
NEXT_PUBLIC_DASHBOARD_INTERACTIVITY=true

# Default values seeded into the client-side DashboardConfig store.
NEXT_PUBLIC_DASHBOARD_DEFAULT_ORGANIZATION_SLUG=
NEXT_PUBLIC_DASHBOARD_DEFAULT_POLLING_INTERVAL_SEC=
NEXT_PUBLIC_DASHBOARD_DEFAULT_METRICS_ENDPOINT=

# Default dashboard window (in minutes) seeded into the WindowSelector. Default: 30.
# Drives the reservations / visitors charts and the "NOUVELLES" / "NOUVEAUX" / "DE RETOUR" KPIs.
NEXT_PUBLIC_DASHBOARD_RESERVATIONS_WINDOW_MINUTES=

# --- Strapi ---
# Base URL of the Strapi admin instance (no trailing slash).
STRAPI_BASE_URL=http://localhost:1337
# Read-only API token generated in Strapi (Settings > API Tokens). Server-only.
STRAPI_API_TOKEN=
# Shared secret between Strapi admin (Settings > Webhooks > custom header
# `X-Webhook-Secret`) and the /api/strapi-webhook receiver. Server-only.
STRAPI_WEBHOOK_SECRET=
