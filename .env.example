# dashboard-monitor — environment variables
#
# Copy this file to `.env.local` and fill in the values.
# NEXT_PUBLIC_* vars are exposed to the browser and must stay non-sensitive
# (driver names, UI knobs). Provider secrets stay server-side only.

# ──────────────────────────────────────────────────────────────────────────
# Providers (drivers)
# Decide which adapter each monitor family loads. Validated by the matching
# factory's create(). Leaving one empty disables that family.
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_ERROR_MONITOR_DRIVER=glitchtip
NEXT_PUBLIC_LOG_MONITOR_DRIVER=glitchtip
NEXT_PUBLIC_TRACKER_MONITOR_DRIVER=posthog

# ──────────────────────────────────────────────────────────────────────────
# GlitchTip (error + log monitor) — server-only secrets
# Required when an error/log driver above is set to `glitchtip`.
# ──────────────────────────────────────────────────────────────────────────
GLITCHTIP_URL=https://app.glitchtip.com
GLITCHTIP_TOKEN=
GLITCHTIP_ORGANIZATION_SLUG=

# ──────────────────────────────────────────────────────────────────────────
# PostHog (tracker monitor) — server-only secrets
# Required when NEXT_PUBLIC_TRACKER_MONITOR_DRIVER=posthog.
# ──────────────────────────────────────────────────────────────────────────
POSTHOG_HOST=https://eu.posthog.com
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=

# ──────────────────────────────────────────────────────────────────────────
# Dashboard — server-only
# ──────────────────────────────────────────────────────────────────────────
# Project shown by default on the home page (required to render the dashboard).
DASHBOARD_DEFAULT_PROJECT_ID=
# Server-side polling interval in milliseconds (default: 30000).
DASHBOARD_REFRESH_INTERVAL_MS=30000

# ──────────────────────────────────────────────────────────────────────────
# Dashboard — public (browser-exposed UI knobs)
# ──────────────────────────────────────────────────────────────────────────
# Title rendered in the dashboard header.
NEXT_PUBLIC_PROJECT_TITLE=UXCO Dashboard Monitor
# Allow user interaction with the dashboard ("true" / "false", default: false).
NEXT_PUBLIC_DASHBOARD_INTERACTIVITY=false
# Reservations time window in minutes (positive integer, default: 30).
NEXT_PUBLIC_DASHBOARD_RESERVATIONS_WINDOW_MINUTES=30
# Environment filter for issues + error rate. Comma-separated list shown in the
# header selector (e.g. production,staging). Empty disables the selector.
NEXT_PUBLIC_DASHBOARD_ENVIRONMENTS=
# Environment selected on load. Must be one of the values above; falls back to
# the first entry, or to "all environments" when the list is empty.
NEXT_PUBLIC_DASHBOARD_DEFAULT_ENVIRONMENT=
# Default config-panel values for the GlitchTip feature.
NEXT_PUBLIC_DASHBOARD_DEFAULT_ORGANIZATION_SLUG=
NEXT_PUBLIC_DASHBOARD_DEFAULT_POLLING_INTERVAL_SEC=30
NEXT_PUBLIC_DASHBOARD_DEFAULT_METRICS_ENDPOINT=
